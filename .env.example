MEETMIND_WEB_PORT=3000
MEETMIND_API_PORT=3452

# Set these when deploying from Docker Hub or another registry.
# Example:
# MEETMIND_WEB_IMAGE=docker.io/<your-dockerhub-user>/meetmind-web:latest
# MEETMIND_API_IMAGE=docker.io/<your-dockerhub-user>/meetmind-api:latest
MEETMIND_WEB_IMAGE=
MEETMIND_API_IMAGE=

# Optional: override Debian package mirrors during image build
DEBIAN_MIRROR=http://deb.debian.org/debian
DEBIAN_SECURITY_MIRROR=http://deb.debian.org/debian-security

# Optional: lower build pressure on small servers
MEETMIND_COMPOSE_PARALLEL_LIMIT=1
PNPM_FILTER=./packages/web...
PNPM_NETWORK_CONCURRENCY=4
PNPM_CHILD_CONCURRENCY=2
NODE_MAX_OLD_SPACE_SIZE=768

AI_PROVIDER=qwen
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_CHAT_MODEL=qwen-plus
QWEN_TRANSCRIPTION_MODEL=qwen3-asr-flash
