# Optional override for the mobile app API endpoint.
# If omitted during local Expo development, the app will try to reuse the Expo host IP
# and call http://<your-computer-ip>:3452/api automatically.

# Real device on the same Wi-Fi as your computer:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3452/api

# Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3452/api

# iOS simulator on macOS:
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3452/api
